{
  "name": "products",
  "version": "1.0.0",
  "main": "build/scr/index.js",
  "scripts": {
    "dev": "npx ts-node-dev --respawn --transpile-only scr/index.ts",
    "dev:debug": "npx ts-node-dev --inspect --respawn scr/index.ts",
    "dev:local": "npm run dev -- --env-file .env.local",
    "prebuild": "npm run clean && npm run test",
    "build": "npm run build:compile",
    "build:compile": "tsc --build tsconfig.json",
    "start": "node build/scr/index.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch --detectOpenHandles",
    "lint": "npx eslint . --fix",
    "lint:check": "npx eslint .",
    "lint:report": "npx eslint scr/ --format json > eslint-report.json",
    "format": "prettier --write scr/**/*.ts",
    "type-check": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate",
    "security": "npm run audit && npm run dep-check",
    "dep-check": "depcheck --ignores='@types/*,jest,typescript'",
    "clean": "rimraf build coverage reports",
    "complexity": "plato -r -d reports/complexity build/scr/",
    "docs": "npx typedoc"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^7.0.3",
    "globals": "^16.3.0",
    "jest": "^30.1.3",
    "jiti": "^2.5.1",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typedoc": "^0.28.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.42.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.5",
    "depcheck": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.18.0",
    "mongoose": "^9.4.1",
    "mysql2": "^3.20.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typhonjs-escomplex": "^0.1.0"
  },
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yatagaratsu666/Servidor-Inventario.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/yatagaratsu666/Servidor-Inventario/issues"
  },
  "homepage": "https://github.com/yatagaratsu666/Servidor-Inventario#readme"
}
